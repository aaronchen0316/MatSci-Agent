# Shared client for all sub-agents. One key/client enough.
MULTIAGENT_API_KEY=replace-me

# Optional. Set when using OpenAI-compatible proxy endpoint.
# Example: https://api.openai.com/v1 or your proxy /v1 endpoint.
MULTIAGENT_BASE_URL=

# Requested default model.
MULTIAGENT_MODEL=gpt-5.4-mini

# Disable tracing by default when using non-OpenAI proxy keys.
MULTIAGENT_DISABLE_TRACING=1

# Keep mutations off until harness behavior looks good.
MULTIAGENT_ENABLE_LIVE_MP=0
MULTIAGENT_ENABLE_GIT_WRITE=0
MULTIAGENT_ENABLE_PRS=0

# Base branch for debugger worktrees.
MULTIAGENT_BASE_BRANCH=multi-agent

# Optional. Needed only when PR tool enabled.
MULTIAGENT_GITHUB_REPO=
